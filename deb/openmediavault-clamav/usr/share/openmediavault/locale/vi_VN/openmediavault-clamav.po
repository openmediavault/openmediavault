msgid "Enable the detection of broken media files (JPEG, TIFF, PNG, GIF)."
msgstr "Kích hoạt tính năng phát hiện các tập tin đa phương tiện bị lỗi hoặc bị hỏng (định dạng: JPEG, TIFF, PNG, GIF)."

