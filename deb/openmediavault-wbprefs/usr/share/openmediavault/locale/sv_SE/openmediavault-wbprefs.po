msgid "Apply"
msgstr "Tillämpa"

msgid "Login"
msgstr "Logga in"

msgid "Page"
msgstr "Sida"

msgid "Reset"
msgstr "Återställ"

msgid "Reset the wallpaper to the default image."
msgstr "Återställ bakgrundsbilden till standardbilden."

msgid "Shutdown"
msgstr "Stäng av"

msgid "Standby"
msgstr "Vänteläge"

msgid "The URL from which the image is to be fetched."
msgstr "URL:en från vilken bilden ska hämtas."

msgid "The URL must start with http://, https:// or file://."
msgstr "URL:en måste börja med http://, https:// eller file://."

msgid "The page for which the wallpaper is to be set."
msgstr "Sidan som bakgrundsbilden ska användas för."

msgid "The wallpaper has been updated."
msgstr "Bakgrundsbilden har uppdaterats."

msgid "URL"
msgstr "URL"

msgid "Wallpaper"
msgstr "Bakgrundsbild"

msgid "You may need to clear your browser's cache to see your changes."
msgstr "Du kan behöva rensa webbläsarens cache för att se dina ändringar."
