msgid "Apply"
msgstr "Εφαρμογή"

msgid "Login"
msgstr "Είσοδος"

msgid "Page"
msgstr "Σελίδα"

msgid "Reset"
msgstr "Επαναφορά"

msgid "Reset the wallpaper to the default image."
msgstr "Επαναφορά του φόντου στην αρχική εικόνα."

msgid "Shutdown"
msgstr "Τερματισμός"

msgid "Standby"
msgstr "Αναμονή"

msgid "The URL from which the image is to be fetched."
msgstr "Το URL από το οποίο θα ανακτηθεί η εικόνα."

msgid "The URL must start with http://, https:// or file://."
msgstr "Το URL πρέπει να ξεκινάει με http://, https:// ή file://."

msgid "The page for which the wallpaper is to be set."
msgstr "Η σελίδα στην οποία θα ρυθμιστεί το φόντο."

msgid "The wallpaper has been updated."
msgstr "Το φόντο έχει ενημερωθεί."

msgid "URL"
msgstr "URL"

msgid "Wallpaper"
msgstr "Φόντο"

msgid "You may need to clear your browser's cache to see your changes."
msgstr ""
"Ίσως χρειαστεί ο καθαρισμός της προσωρινής μνήμης για να εμφανιστούν οι "
"αλλαγές."
