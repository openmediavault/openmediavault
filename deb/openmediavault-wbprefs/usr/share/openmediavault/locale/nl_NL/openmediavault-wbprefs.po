msgid "Apply"
msgstr "Toepassen"

msgid "Login"
msgstr "Aanmelden"

msgid "Page"
msgstr "Pagina"

msgid "Reset"
msgstr "Herstellen"

msgid "Reset the wallpaper to the default image."
msgstr "De achtergrond herstellen naar de standaardafbeelding."

msgid "Shutdown"
msgstr "Uitschakelen"

msgid "Standby"
msgstr "Stand-by"

msgid "The URL from which the image is to be fetched."
msgstr "De URL waaruit de image moet worden opgehaald."

msgid "The URL must start with http://, https:// or file://."
msgstr "De URL moet beginnen met http://, https:// of file://."

msgid "The page for which the wallpaper is to be set."
msgstr "De pagina waarvoor de achtergrond moet worden ingesteld."

msgid "The wallpaper has been updated."
msgstr "De achtergrond is bijgewerkt."

msgid "URL"
msgstr "URL"

msgid "Wallpaper"
msgstr "Achtergrond"

msgid "You may need to clear your browser's cache to see your changes."
msgstr ""
"Mogelijk moet u de cache van uw browser wissen om uw wijzigingen te zien."
