{
	"type": "config",
	"id": "conf.system.tfatotp",
	"title": "2FA TOTP authentication",
	"queryinfo": {
		"xpath": ".//system/tfatotp/item",
		"iterable": true,
		"idproperty": "uuid"
	},
	"properties": {
		"uuid": {
			"type": "string",
			"format": "uuidv4"
		},
		"name": {
			"type": "string",
			"format": "username",
			"default": ""
		},
		"enabled": {
			"type": "boolean",
			"default": false
		},
		"secret": {
			"type": "string",
			"default": ""
		}
	}
}
