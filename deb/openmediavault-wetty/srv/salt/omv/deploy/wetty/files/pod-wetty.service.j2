{{ pillar['headers']['multiline'] -}}
[Unit]
Description=Podman pod-wetty.service
Wants=network.target
After=network-online.target
Requires=container-wetty-app.service container-wetty-proxy.service
Before=container-wetty-app.service container-wetty-proxy.service

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=on-failure
TimeoutStopSec=70
ExecStartPre=/bin/rm -f %t/pod-wetty.pid %t/pod-wetty.pod-id
ExecStartPre=/usr/bin/podman pod create --infra-conmon-pidfile %t/pod-wetty.pid --pod-id-file %t/pod-wetty.pod-id --name=wetty -p {{ wetty_config.port }}:8443 --replace
ExecStart=/usr/bin/podman pod start --pod-id-file %t/pod-wetty.pod-id
ExecStop=/usr/bin/podman pod stop --ignore --pod-id-file %t/pod-wetty.pod-id
ExecStopPost=/usr/bin/podman pod rm --ignore -f --pod-id-file %t/pod-wetty.pod-id
PIDFile=%t/pod-wetty.pid
Type=forking

[Install]
WantedBy=multi-user.target default.target
