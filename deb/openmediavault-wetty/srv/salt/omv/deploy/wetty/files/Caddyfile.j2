{
  admin off
  auto_https off
}
:8443 {
{%- if config.sslcertificateref | length > 0 %}
  tls /data/cert.crt /data/cert.key
{%- endif %}

  reverse_proxy wetty-app:3000 {
    header_down -Content-Security-Policy
    header_down -Strict-Transport-Security
    header_down -Cross-Origin-Opener-Policy
    header_down -Cross-Origin-Resource-Policy
  }
}
