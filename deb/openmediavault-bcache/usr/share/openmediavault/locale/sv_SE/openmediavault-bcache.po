msgstr "Oregistrerad"

msgid "Unused"
msgstr "Oanvänd"

msgid "Updated backing device '{{ devicefile }}'."
msgstr "Den bakomliggande enheten ”{{ devicefile }}” uppdaterades."

msgid "Updated cache device '{{ devicefile }}'."
msgstr "Cacheenheten ”{{ devicefile }}” uppdaterades."

msgid ""
"When dirty data is written to the cache and it previously did not contain "
"any, waits some number of seconds before initiating writeback. (default:30)"
msgstr ""
"När ändrade data skrivs till en tidigare ren cache väntar systemet det "
"angivna antalet sekunder innan återskrivningen påbörjas (standard: 30)."

msgid "Writeback Delay"
msgstr "Fördröjning före återskrivning"

msgid "Writeback Percent"
msgstr "Återskrivningsandel"

