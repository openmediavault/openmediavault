msgstr "Statistik"

msgid "Superblock"
msgstr "Superblock"

msgid "The default is 2000 us (2 milliseconds)"
msgstr "Standardvärdet är 2 000 µs (2 millisekunder)"

msgid "The default is 20000 us (20 milliseconds)"
msgstr "Standardvärdet är 20 000 µs (20 millisekunder)"

msgid "Total"
msgstr "Totalt"

msgid "Unit"
msgstr "Enhet"

