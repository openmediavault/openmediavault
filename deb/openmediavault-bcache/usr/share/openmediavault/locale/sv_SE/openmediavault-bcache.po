msgstr "Rensa totalstatistik"

msgid "Configuration"
msgstr "Konfiguration"

msgid "Congest Tracking"
msgstr "Överbelastningsspårning"

msgid "Congested Read Threshold (us)"
msgstr "Tröskel för överbelastad läsning (µs)"

msgid "Create"
msgstr "Skapa"

msgid "Day"
msgstr "Dag"

