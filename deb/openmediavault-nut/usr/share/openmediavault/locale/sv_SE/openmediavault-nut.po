msgid ""
"'Standalone' for local UPS, 'Netclient' for remote UPS on a NUT server."
msgstr "”Standalone” för en lokal UPS och ”Netclient” för en fjärransluten UPS på en NUT-server."

msgid "Charge"
msgstr "Laddning"

msgid "Comment"
msgstr "Kommentar"

msgid "Date & Time"
msgstr "Datum och tid"

msgid "Defines when the shutdown is initiated."
msgstr "Anger när avstängningen initieras."

msgid "Driver configuration directives"
msgstr "Direktiv för drivrutinskonfiguration"

msgid "Enable remote monitoring of the local connected UPS."
msgstr "Aktivera fjärrövervakning för den lokalt anslutna UPS:en."

msgid "Enabled"
msgstr "Aktiverad"

msgid "Identifier"
msgstr "Identifierare"

msgid "Invalid identifier"
msgstr "Ogiltig identifierare"

msgid "Load"
msgstr "Belastning"

msgid "Message"
msgstr "Meddelande"

msgid "Mode"
msgstr "Läge"

msgid "Netclient"
msgstr "Netclient"

msgid "Netclient hostname"
msgstr "Netclient-värdnamn"

msgid "Netclient password"
msgstr "Netclient-lösenord"

msgid "Netclient user name"
msgstr "Netclient-användarnamn"

msgid "PID"
msgstr "PID"

msgid "Password"
msgstr "Lösenord"

msgid "Powervalue"
msgstr "Effektvärde"

msgid "Program"
msgstr "Program"

msgid "Remote monitoring"
msgstr "Fjärrövervakning"

msgid "Service disabled"
msgstr "Tjänst inaktiverad"

msgid "Shutdown mode"
msgstr "Avstängningsläge"

msgid "Shutdown timer"
msgstr "Tidsgräns före avstängning"

msgid "Standalone"
msgstr "Standalone"

msgid "Temperature"
msgstr "Temperatur"

msgid "The name used to uniquely identify your UPS on local or remote system."
msgstr "Namnet som unikt identifierar UPS-enheten på det lokala systemet eller ett fjärrsystem."

msgid ""
"The number of power supplies that the UPS feeds on this system (usually 1), "
"refer to <a href='https://networkupstools.org/docs/man/upsmon.conf.html' "
"target='_blank'>upsmon.conf(5)</a> for more information."
msgstr "Antalet strömförsörjningsenheter som UPS-enheten försörjer i systemet, vanligtvis 1. Mer information finns i <a href='https://networkupstools.org/docs/man/upsmon.conf.html' target='_blank'>upsmon.conf(5)</a>."

msgid ""
"The time in seconds until shutdown is initiated. If the UPS happens to come "
"back before the time is up the shutdown is canceled."
msgstr "Tiden i sekunder till avstängningen initieras. Om UPS:en kommer tillbaka innan tiden är slut kommer avstängningen att avbrytas."

msgid ""
"To get more information how to configure your UPS please check the Network "
"UPS Tools <a href='http://www.networkupstools.org/docs/man/ups.conf.html' "
"target='_blank'>documentation</a>."
msgstr "Mer information om hur UPS-enheten konfigureras finns i <a href='http://www.networkupstools.org/docs/man/ups.conf.html' target='_blank'>dokumentationen för Network UPS Tools</a>."

msgid "UPS"
msgstr "UPS"

msgid "UPS goes on battery"
msgstr "UPS-enheten går över till batteridrift"

msgid "UPS reaches low battery"
msgstr "UPS-enheten når låg batterinivå"

msgid "Updated UPS settings."
msgstr "UPS-inställningarna uppdaterades."

msgid "Used for remote authentication."
msgstr "Används för fjärrautentisering."

msgid "User name"
msgstr "Användarnamn"

msgid "Voltage"
msgstr "Spänning"
