{
	"type": "config",
	"id": "conf.system.apt.updates",
	"queryinfo": {
		"xpath": ".//system/apt/updates",
		"iterable": false
	},
	"properties": {
		"unattendedupgrade": {
			"type": "boolean",
			"default": true
		},
		"notificationschedule": {
			"type": "string",
			"default": "daily",
			"enum": [ "daily", "weekly" ]
		}
	}
}
