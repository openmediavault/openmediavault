msgid ""
"<ul><li>Full - Replicate changes from and to OneDrive.</li><li>Download only"
" - Replicate the OneDrive online state locally, by only downloading changes "
"from OneDrive. Do not upload local changes to OneDrive.</li><li>Upload only "
"- Replicate the local state to OneDrive, by only uploading local changes to "
"OneDrive. Do not download changes from OneDrive.</li></ul>"
msgstr ""

msgid ""
"After enabling and deploying this service the first time please run the "
"command <em>omv-onedrive-auth</em> as <em>root</em> user in the CLI to "
"authenticate the application in Microsoft OneDrive."
msgstr ""

